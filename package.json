{
  "name": "mobile-automation-wdio-appium",
  "version": "1.0.0",
  "description": "Automação de testes mobile usando WebdriverIO, Appium e Mocha",
  "main": "index.js",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:android": "wdio run wdio.conf.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "keywords": [
    "webdriverio",
    "appium",
    "mobile",
    "automation",
    "testing",
    "android",
    "mocha",
    "allure"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@wdio/allure-reporter": "^8.36.1",
    "@wdio/appium-service": "^8.36.1",
    "@wdio/cli": "^8.36.1",
    "@wdio/local-runner": "^8.36.1",
    "@wdio/mocha-framework": "^8.36.1",
    "@wdio/spec-reporter": "^8.36.1",
    "allure-commandline": "^2.27.0",
    "appium": "^2.5.1",
    "appium-uiautomator2-driver": "^3.0.4",
    "chai": "^4.3.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
